# Copy to .env or export these in your shell

# === REQUIRED ===
# For local Docker setup (recommended for chat-based development):
DATABASE_URL=postgres://dev:dev@localhost:5432/starfield_dev

# For hosted DBs (Neon, Supabase, Render Postgres, etc.):
# DATABASE_URL=postgres://user:pass@host:5432/dbname?sslmode=require

# === OPTIONAL (sensible defaults now exist) ===
# API port (default 5000)
PORT=5000

# Web / Vite port (default 5173)
# When running `pnpm --filter @workspace/starfield run dev`, Vite reads PORT too.
# PORT=5173

# Base path for the SPA (default "/")
# BASE_PATH=/

# Point the generated API client at a different origin (prod, or when not using the Vite proxy)
# Must be set at dev or build time for Vite to embed it.
# VITE_API_BASE_URL=https://api.yourdomain.com

# Production single-origin mode: make the API server also serve the built frontend
# (after you have run the starfield build)
# SERVE_FRONTEND=1
# FRONTEND_DIST=/absolute/path/to/artifacts/starfield/dist/public
